{
  "name": "shedit",
  "version": "0.0.1",
  "description": "Shiki highlighted textarea",
  "license": "MIT",
  "author": "Ryuz <ryuzer@proton.me>",
  "files": [
    "dist"
  ],
  "type": "module",
  "module": "src/index.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsdown && bun run styles",
    "test": "bun --hot test/index.html",
    "demo": "bun build test/index.html --outdir demo",
    "styles": "bunx @tailwindcss/cli -i ./src/styles.css -o ./dist/styles.css",
    "fmt": "oxfmt"
  },
  "dependencies": {
    "@sylphx/synth": "^0.3.2",
    "twoslash-protocol": "^0.3.6"
  },
  "devDependencies": {
    "@sylphx/synth-js": "^0.3.3",
    "@sylphx/synth-rust": "^0.3.1",
    "@tailwindcss/cli": "^4.2.2",
    "@types/bun": "latest",
    "oxfmt": "^0.41.0",
    "tailwindcss": "^4.2.2",
    "tsdown": "^0.21.4",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "shiki": "^4",
    "typescript": "^5"
  }
}
